{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "redirects": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "www.markbuilds.ai"
        }
      ],
      "destination": "https://markbuilds.ai/",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.markbuilds.ai"
        }
      ],
      "destination": "https://markbuilds.ai/:path*",
      "permanent": true
    }
  ]
}
